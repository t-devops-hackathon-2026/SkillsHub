# Database
# ローカル開発: compose.yaml で起動するローカル Postgres を見る。
# デプロイ環境ではこの変数を設定せず、Secret Manager から取得する。
DATABASE_URL=postgresql+psycopg://skillhub_user:password@127.0.0.1:5433/skillhub

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=（aistudio.google.com/apikey で発行したキー）

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=path/to/private-key.pem

# Vertex AI
VERTEX_AI_LOCATION=asia-northeast1

# 鮮度判定しきい値（日数）
UPDATE_NEW_DAYS=90
UPDATE_STALE_DAYS=180

# 重複検出しきい値
DEDUP_SIMILARITY_THRESHOLD=0.88
